{
  "name": "sf-fls-manager",
  "displayName": "SF-FLS-MANAGER",
  "description": "VS Code extension to review and apply Salesforce field-level security across profiles and permission sets using a shared JSON config.",
  "version": "0.1.1",
  "publisher": "thephani",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/thephani/SF-FLS-Manager"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:salesforce.openFlsConfigBuilder"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "salesforce.openFlsConfigBuilder",
        "title": "Open FLS Commit Manager",
        "category": "Salesforce"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "echo \"No lint configured\"",
    "test": "echo \"No tests configured\""
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "fast-xml-parser": "^4.4.0"
  },
  "icon": "images/icon.png"
}
